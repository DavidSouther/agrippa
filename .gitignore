.superpowers/
.env

# Local `kustomize build --enable-helm` chart-pull cache.
# ArgoCD's repo-server pulls charts server-side into its own cache; this is purely a
# side effect of local verification runs, never git-tracked content.
core/overlays/dev/*/charts/
storage/overlays/dev/*/charts/
observability/overlays/dev/*/charts/
platform/overlays/dev/*/charts/
platform/overlays/dev/*/chart/charts/
